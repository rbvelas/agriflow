# ════════════════════════════════════════════════════════════════════
# AgriFlow — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# ¡NUNCA subas el .env real a git!
# ════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agriflow
POSTGRES_USER=agriflow_user
POSTGRES_PASSWORD=cambiar_en_produccion_seguro_min16chars

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Backend NestJS ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
JWT_SECRET=super_secreto_min_32_chars_cambiar_en_produccion
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# ── ML Service ────────────────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8000
ML_MODEL_PATH=/app/model/ensemble_v1.pkl

# ── n8n ───────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=token_secreto_n8n_min_20_chars
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=agriflow_n8n_2024
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://n8n:5678

# ── Frontend Next.js ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=AgriFlow

# ── CI/CD (solo para GitHub Actions) ─────────────────────────────
# VERCEL_TOKEN=...
# DOCKERHUB_USERNAME=...
# DOCKERHUB_TOKEN=...
